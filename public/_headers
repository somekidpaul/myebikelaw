# Security headers for Cloudflare Pages (applied to every response).
# CSP is scoped to exactly what the site loads: its own bundle, Google Fonts,
# and data: URIs (the inline SVG chevron). No external scripts, no analytics,
# no network calls — so connect-src is 'self'. 'unsafe-inline' is required for
# React's inline style attributes and the JSON-LD block; everything else is
# locked to same-origin. frame-ancestors + X-Frame-Options block clickjacking.
/*
  Strict-Transport-Security: max-age=31536000
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; connect-src 'self'
